<section class="py-32 md:py-48 px-6 bg-[#F9F8F6] dark:bg-[#1A1918]">
  <!-- Terminal Header -->
  <div class="font-mono text-sm uppercase tracking-widest text-[#121212]/50 dark:text-[#EBE9E4]/50 flex items-center justify-center mb-6">
    &gt; SYS.DICTIONARY // REDEFINING_COMMUNITY
  </div>

  <!-- Headline -->
  <h2 class="font-heading text-5xl md:text-6xl lg:text-7xl font-black uppercase italic tracking-tighter leading-[1.1] text-center text-[#121212] dark:text-[#EBE9E4] mb-16 max-w-4xl mx-auto">
    Most Communities Are Just Glorified Inboxes.
  </h2>

  <!-- Comparison Grid -->
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
    <!-- Left Column: The Illusion -->
    <div class="p-8 lg:p-12 border border-black/10 dark:border-white/10 rounded-[2rem] bg-black/5 dark:bg-white/5 opacity-70">
      <div class="font-mono text-xs text-[#FF5733] mb-6 tracking-widest uppercase">[ THE_ILLUSION ]</div>
      <h3 class="text-3xl font-bold uppercase tracking-tight text-[#121212] dark:text-[#EBE9E4] mb-8">A Rented Chat Room</h3>
      <ul class="list-none">
        <li class="text-lg text-[#121212]/70 dark:text-[#EBE9E4]/70 leading-relaxed mb-4 border-b border-black/5 dark:border-white/5 pb-4">
          A Slack channel where you talk <strong class="font-bold text-[#121212] dark:text-[#EBE9E4]">AT</strong> your audience.
        </li>
        <li class="text-lg text-[#121212]/70 dark:text-[#EBE9E4]/70 leading-relaxed mb-4 border-b border-black/5 dark:border-white/5 pb-4">
          An exhausting content treadmill that dies the second you log off.
        </li>
        <li class="text-lg text-[#121212]/70 dark:text-[#EBE9E4]/70 leading-relaxed">
          A massive liability filled with passive lurkers who never buy.
        </li>
      </ul>
    </div>

    <!-- Right Column: The Architecture -->
    <div class="p-8 lg:p-12 border-2 border-[#FF5733] rounded-[2rem] bg-[#121212] dark:bg-[#1A1918] shadow-2xl shadow-[#FF5733]/10 relative overflow-hidden group">
      <div class="font-mono text-xs text-green-400 mb-6 tracking-widest uppercase flex items-center">
        <span class="w-2 h-2 rounded-full bg-green-500 mr-2 animate-pulse"></span>
        [ THE_ARCHITECTURE ]
      </div>
      <h3 class="text-3xl font-bold uppercase tracking-tight text-white mb-8">A Defensible Ecosystem</h3>
      <ul class="list-none">
        <li class="text-lg text-white/70 leading-relaxed mb-4 border-b border-white/10 pb-4">
          A self-sustaining environment where members elevate <strong class="font-bold text-white">EACH OTHER</strong>.
        </li>
        <li class="text-lg text-white/70 leading-relaxed mb-4 border-b border-white/10 pb-4">
          A peer-driven engine that generates organic, high-ticket referrals.
        </li>
        <li class="text-lg text-white/70 leading-relaxed">
          A compounding business asset that scales your culture and your ARR automatically.
        </li>
      </ul>
    </div>
  </div>

  <!-- Ghost Link -->
  <div class="mt-16 text-center flex flex-col items-center justify-center group">
    <span class="font-mono text-[10px] text-[#121212]/40 dark:text-[#EBE9E4]/40 uppercase tracking-widest mb-3">&gt; REQUIRE_DEEPER_CONTEXT?</span>
    <a href="/thesis" class="font-mono text-sm md:text-base uppercase tracking-widest text-[#121212]/70 dark:text-[#EBE9E4]/70 hover:text-[#FF5733] dark:hover:text-[#FF5733] transition-colors duration-300 flex items-center gap-3">
      [ READ_THE_FULL_THESIS ]
      <svg class="w-4 h-4 group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
    </a>
  </div>
</section>

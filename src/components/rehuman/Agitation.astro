---
---

<section class="bg-warm-light dark:bg-warm-dark min-h-screen flex flex-col justify-center py-40 md:py-52 px-6 md:px-10" id="agitation-section">
  <div class="mx-auto w-full max-w-[1400px]">
    <!-- System Header -->
    <div class="mb-16 md:mb-20">
      <p class="font-mono text-xs uppercase tracking-widest text-ember">
        &gt; SYS.DIAGNOSTIC // THE_PROBLEM
      </p>
    </div>

    <!-- Two-column layout: Copy left, Counter right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-start">
      <!-- Left: Copy -->
      <div class="agitation-reveal">
        <h2 class="font-heading text-4xl md:text-6xl lg:text-[56px] xl:text-7xl font-black uppercase italic tracking-tight leading-[0.95] text-text-light dark:text-text-dark mb-8">
          An audience is just<br />rented attention.
        </h2>
        <p class="text-lg md:text-xl text-text-light/60 dark:text-text-dark/60 leading-relaxed max-w-lg">
          When AI can generate infinite content, competing for eyeballs is a race to the bottom. If you are just broadcasting to passive consumers, a change in the algorithm can erase you tomorrow. Audiences are fleeting. <em class="text-ember not-italic font-semibold">Communities are forever.</em>
        </p>
      </div>

      <!-- Right: Decay Counter -->
      <div class="agitation-reveal border border-text-light/10 dark:border-text-dark/10 p-8 md:p-10">
        <div class="flex items-center gap-3 mb-8">
          <span class="block w-2 h-2 rounded-full bg-ember/40"></span>
          <span class="font-mono text-[10px] uppercase tracking-widest text-text-light/40 dark:text-text-dark/40">LIVE DIAGNOSTIC</span>
        </div>

        <!-- Big Counter -->
        <div class="mb-8">
          <p class="font-mono text-[10px] uppercase tracking-widest text-text-light/40 dark:text-text-dark/40 mb-3">
            BROADCASTS_SENT_TODAY:
          </p>
          <p class="font-mono text-3xl md:text-4xl lg:text-5xl font-bold text-text-light dark:text-text-dark tabular-nums tracking-tight" id="decay-counter">
            0
          </p>
        </div>

        <!-- Contrast Stats -->
        <div class="border-t border-text-light/10 dark:border-text-dark/10 pt-6 grid grid-cols-2 gap-6">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-widest text-text-light/40 dark:text-text-dark/40 mb-2">
              REAL_CONNECTIONS:
            </p>
            <p class="font-mono text-3xl md:text-4xl font-bold text-ember tabular-nums">
              12
            </p>
          </div>
          <div>
            <p class="font-mono text-[10px] uppercase tracking-widest text-text-light/40 dark:text-text-dark/40 mb-2">
              RETENTION_RATE:
            </p>
            <p class="font-mono text-3xl md:text-4xl font-bold text-text-light/15 dark:text-text-dark/15 tabular-nums">
              0.02%
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Reveal animations
  gsap.fromTo(
    ".agitation-reveal",
    { opacity: 0, y: 50 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.3,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#agitation-section",
        start: "top 70%",
      },
    }
  );

  // Decay counter — starts when visible, rapidly increments
  const counterEl = document.getElementById("decay-counter");
  if (counterEl) {
    let count = 3_847_291_044;
    let running = false;

    function formatNumber(n: number): string {
      return n.toLocaleString("en-US");
    }

    function tick() {
      if (!running) return;
      count += Math.floor(Math.random() * 800) + 200;
      counterEl!.textContent = formatNumber(count);
      requestAnimationFrame(tick);
    }

    ScrollTrigger.create({
      trigger: "#agitation-section",
      start: "top 60%",
      onEnter: () => {
        if (!running) {
          running = true;
          counterEl.textContent = formatNumber(count);
          tick();
        }
      },
    });
  }
</script>

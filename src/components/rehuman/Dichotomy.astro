---
const audiencePoints = [
  "1-to-Many Broadcasting",
  "Transactional Interactions",
  "Dependent on Algorithms",
  "High Churn, Low Loyalty",
];

const communityPoints = [
  "Many-to-Many Connection",
  "Relational Ecosystems",
  "Platform Agnostic",
  "Self-Sustaining Culture",
];
---

<section class="py-32 px-6 md:px-10" id="dichotomy-section">
  <!-- Terminal Header -->
  <div class="w-full flex justify-center items-center mb-8">
    <h2 class="font-mono text-sm uppercase text-ember dark:text-[#EBE9E4]/50 tracking-widest flex items-center">
      &gt; SYS.ANALYSIS // THE_DICHOTOMY
    </h2>
  </div>

  <!-- Massive Header -->
  <div class="mx-auto max-w-[1400px] mb-16 md:mb-24 text-center">
    <h2 class="dichotomy-header font-heading text-6xl md:text-8xl font-black uppercase italic tracking-tighter leading-[0.9] text-text-light dark:text-text-dark">
      Audience vs.<br />Community.
    </h2>
  </div>

  <!-- The Split Screen -->
  <div class="mx-auto max-w-[1400px]">
    <div class="flex flex-col md:flex-row min-h-[60vh]">
      <!-- LEFT: The Algorithmic Audience -->
      <div class="dichotomy-col flex-1 flex flex-col justify-center bg-[#F9F8F6] p-12 md:p-24">
        <p class="font-mono text-xs uppercase tracking-widest text-black/30 mb-16">
          &gt; SYS.ERROR // THE AUDIENCE
        </p>
        <ul class="space-y-16">
          {audiencePoints.map((point) => (
            <li>
              <span class="font-heading text-3xl md:text-5xl font-black uppercase tracking-tighter text-black/20 leading-[1]">
                {point}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- RIGHT: The re/Human Community -->
      <div class="dichotomy-col flex-1 flex flex-col justify-center bg-[#1A1918] p-12 md:p-24">
        <p class="font-mono text-xs uppercase tracking-widest text-ember mb-16">
          <span class="inline-block w-2 h-2 rounded-full bg-ember animate-pulse mr-2 align-middle"></span>
          SYS.ACTIVE // THE COMMUNITY
        </p>
        <ul class="space-y-16">
          {communityPoints.map((point) => (
            <li>
              <span class="font-heading text-3xl md:text-5xl font-black uppercase tracking-tighter text-[#EBE9E4] leading-[1]">
                {point}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(
    ".dichotomy-header",
    { opacity: 0, y: 40 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#dichotomy-section",
        start: "top 70%",
      },
    }
  );

  gsap.fromTo(
    ".dichotomy-col",
    { opacity: 0, y: 50 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.25,
      ease: "power3.out",
      scrollTrigger: {
        trigger: ".dichotomy-col",
        start: "top 80%",
      },
    }
  );
</script>

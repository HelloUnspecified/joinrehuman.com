---
const audiencePoints = [
  "The \"8th-Grade Dance\" Dynamic",
  "Hunting for Outbound Clients",
  "Dependency on Algorithms",
  "High Churn, Low LTV",
];

const communityPoints = [
  "Peer-to-Peer Facilitation",
  "Inbound, Undeniable Authority",
  "Platform Agnostic Ecosystems",
  "Fierce, Self-Sustaining Loyalty",
];
---

<section class="py-32 px-6 md:px-10" id="dichotomy-section">
  <!-- Terminal Header -->
  <div class="w-full flex justify-center items-center mb-8">
    <h2 class="font-mono text-sm uppercase text-ember dark:text-[#EBE9E4]/50 tracking-widest flex items-center">
      &gt; SYS.ANALYSIS // THE_DICHOTOMY
    </h2>
  </div>

  <!-- Massive Header -->
  <div class="mx-auto max-w-[1400px] mb-16 md:mb-24 text-center">
    <h2 class="dichotomy-header font-heading text-6xl md:text-8xl font-black uppercase italic tracking-tighter leading-[0.9] text-text-light dark:text-text-dark">
      The Crowd vs.<br />The Culture.
    </h2>
  </div>

  <!-- The Split Screen -->
  <div class="mx-auto max-w-[1400px]" id="dichotomy-split">
    <div class="flex flex-col md:flex-row min-h-[60vh] md:items-stretch">
      <!-- LEFT: The Algorithmic Audience -->
      <div class="dichotomy-col flex-1 flex flex-col justify-start bg-[#F9F8F6] p-12 md:p-24">
        <p class="font-mono text-xs uppercase tracking-widest text-black/30 mb-16">
          &gt; SYS.ERROR // THE AUDIENCE
        </p>
        <ul class="space-y-16">
          {audiencePoints.map((point) => (
            <li class="old-paradigm-item">
              <span class="font-heading text-3xl md:text-5xl font-black uppercase tracking-tighter text-[#121212]/50 leading-none transition-all duration-300">
                {point}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- RIGHT: The re/Human Community -->
      <div class="dichotomy-col flex-1 flex flex-col justify-start bg-[#1A1918] p-12 md:p-24">
        <p class="font-mono text-xs uppercase tracking-widest text-ember mb-16">
          <span class="inline-block w-2 h-2 rounded-full bg-ember animate-pulse mr-2 align-middle"></span>
          SYS.ACTIVE // THE COMMUNITY
        </p>
        <ul class="space-y-16">
          {communityPoints.map((point) => (
            <li class="new-paradigm-item">
              <span class="font-heading text-3xl md:text-5xl font-black uppercase tracking-tighter text-[#EBE9E4] leading-none">
                {point}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Header reveal
  gsap.fromTo(
    ".dichotomy-header",
    { opacity: 0, y: 40 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#dichotomy-section",
        start: "top 70%",
      },
    }
  );

  // Column reveal
  gsap.fromTo(
    ".dichotomy-col",
    { opacity: 0, y: 50 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.25,
      ease: "power3.out",
      scrollTrigger: {
        trigger: ".dichotomy-col",
        start: "top 80%",
      },
    }
  );

  // The Deprecation Shift
  gsap.context(() => {
    const oldItems = gsap.utils.toArray<HTMLElement>(".old-paradigm-item");
    const newItems = gsap.utils.toArray<HTMLElement>(".new-paradigm-item");

    // Start new items hidden
    gsap.set(newItems, { opacity: 0, y: 20 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#dichotomy-section",
        start: "top top",
        end: "+=150%",
        scrub: 1,
        pin: true,
      },
    });

    // Stagger through each pair
    for (let i = 0; i < oldItems.length; i++) {
      const offset = i * 1.2;

      // Deprecate old item
      tl.to(
        oldItems[i].querySelector("span")!,
        {
          opacity: 0.15,
          textDecoration: "line-through",
          duration: 0.5,
          ease: "power2.inOut",
        },
        offset
      );

      // Illuminate new item
      tl.to(
        newItems[i],
        {
          opacity: 1,
          y: 0,
          duration: 0.5,
          ease: "power2.out",
        },
        offset
      );
    }
  });
</script>

---
---

<footer class="bg-[#1A1918] text-[#EBE9E4] pt-32 pb-12 px-6 rounded-t-[4rem] mt-24">
  <div class="mx-auto max-w-[1400px]">
    <!-- Newsletter Section -->
    <div class="mb-0">
      <!-- Terminal Header -->
      <p class="font-mono text-sm uppercase tracking-widest text-[#EBE9E4]/50 flex items-center">
        &gt; SYS.ARCHIVE // LONG_FORM
      </p>

      <!-- Headline -->
      <h2 class="font-heading text-5xl md:text-7xl font-black uppercase tracking-tighter text-[#EBE9E4] mt-6">
        Read the Manual.
      </h2>

      <!-- Body -->
      <p class="text-xl text-[#EBE9E4]/70 max-w-2xl mt-4 mb-12">
        Join our dispatch for deep dives into culture design and community architecture.
      </p>

      <!-- Email Input -->
      <form class="flex flex-col md:flex-row max-w-2xl gap-4">
        <input
          type="email"
          placeholder="enter_email_address..."
          class="bg-transparent border-b-2 border-[#EBE9E4]/30 text-[#EBE9E4] px-4 py-4 focus:outline-none focus:border-[#FF5733] transition-colors w-full font-mono placeholder:text-[#EBE9E4]/30"
        />
        <button
          type="submit"
          class="font-mono text-sm uppercase tracking-widest text-[#FF5733] px-8 py-4 border border-transparent hover:border-[#FF5733] transition-colors shrink-0"
        >
          [ EXECUTE ]
        </button>
      </form>
    </div>

    <!-- System Readout Bottom Bar -->
    <div class="mt-32 pt-8 border-t border-[#EBE9E4]/10 flex flex-col md:flex-row justify-between items-center gap-6">
      <!-- Left: Copyright -->
      <span class="font-mono text-xs uppercase tracking-widest text-[#EBE9E4]/50">
        &copy; 2026 RE/HUMAN. ALL RIGHTS RESERVED.
      </span>

      <!-- Center: System Status -->
      <div class="font-mono text-xs uppercase tracking-widest text-[#EBE9E4]/50 flex items-center">
        <span class="inline-block w-2 h-2 rounded-full bg-[#FF5733] animate-pulse mr-2"></span>
        <span class="text-[#FF5733]">HUMAN PROTOCOL // ACTIVE</span>
      </div>

      <!-- Right: Site Index -->
      <nav class="flex items-center gap-8">
        <a href="/contact" class="font-mono text-xs uppercase tracking-widest text-[#EBE9E4]/50 hover:text-[#FF5733] transition-colors duration-300">//Articles</a>
        <a href="/faq" class="font-mono text-xs uppercase tracking-widest text-[#EBE9E4]/50 hover:text-[#FF5733] transition-colors duration-300">//FAQ</a>
        <a href="/about" class="font-mono text-xs uppercase tracking-widest text-[#EBE9E4]/50 hover:text-[#FF5733] transition-colors duration-300">//About_Us</a>
        <a href="/contact" class="font-mono text-xs uppercase tracking-widest text-[#EBE9E4]/50 hover:text-[#FF5733] transition-colors duration-300">//Contact</a>
      </nav>
    </div>
  </div>
</footer>

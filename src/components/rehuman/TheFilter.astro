---
---

<section class="relative min-h-screen flex flex-col justify-center items-center w-full px-6 bg-[#F9F8F6] overflow-hidden" id="filter-section">
  <!-- Centered Terminal Header — in normal flow above text -->
  <div class="w-full text-center mb-16">
    <p class="font-mono text-xs md:text-sm uppercase tracking-widest text-[#121212]/50 dark:text-[#EBE9E4]/50 flex items-center justify-center">
      &gt; SYS.FIREWALL // QUALIFICATION_CHECK
    </p>
  </div>

  <!-- Text Block Wrapper — fixed height, holds all 3 blocks -->
  <div class="relative w-full max-w-5xl mx-auto text-center h-[50vh] md:h-[40vh] flex items-center justify-center">
    <!-- Block 1: The Rejection -->
    <div id="filter-block-1" class="absolute top-0 left-0 w-full h-full flex flex-col justify-center items-center px-4">
      <p class="font-heading text-5xl md:text-7xl font-black uppercase tracking-tighter italic leading-[1.1] text-[#121212] dark:text-[#EBE9E4]">
        If you want to hack algorithms, spam DMs, or build a temporary Discord just to upsell a course...
      </p>
      <a
        href="/book"
        class="inline-block mt-8 px-8 py-4 border-4 border-[#121212] text-[#121212] font-heading text-xl md:text-2xl font-black uppercase italic tracking-tighter hover:bg-[#121212] hover:text-[#F9F8F6] transition-colors cursor-pointer underline decoration-4 underline-offset-8"
      >
        Close This Tab.
      </a>
    </div>

    <!-- Block 2: The Acceptance -->
    <div id="filter-block-2" class="absolute top-0 left-0 w-full h-full flex flex-col justify-center items-center px-4 opacity-0">
      <p class="font-heading text-5xl md:text-7xl font-black uppercase tracking-tighter italic leading-[1.1] text-[#121212] dark:text-[#EBE9E4]">
        If you want to translate your raw expertise into a self-sustaining ecosystem, where your people defend your mission in rooms you aren't even in,
      </p>
      <p class="font-heading text-5xl md:text-7xl font-black uppercase tracking-tighter italic leading-none text-ember mt-6">
        You belong here.
      </p>
    </div>

    <!-- Block 3: The Invitation -->
    <div id="filter-block-3" class="absolute top-0 left-0 w-full h-full flex flex-col justify-center items-center px-4 opacity-0">
      <p class="font-heading text-5xl md:text-7xl font-black uppercase tracking-tighter italic leading-[1.1] text-[#121212] dark:text-[#EBE9E4]">
        Because a massive audience without culture is just a room full of strangers.
      </p>
      <p class="font-heading text-5xl md:text-7xl font-black uppercase tracking-tighter italic leading-none text-ember mt-6">
        We architect belonging.
      </p>
      <p class="font-heading text-2xl uppercase italic tracking-tighter text-[#121212]/50 dark:text-[#EBE9E4]/50 mt-8">
        Welcome to the family.
      </p>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.context(() => {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#filter-section",
        start: "top top",
        end: "+=300%",
        scrub: 1,
        pin: true,
      },
    });

    // --- State 1 → State 2: Block 1 out, Block 2 in ---

    // Block 1 blurs, shrinks, fades
    tl.to(
      "#filter-block-1",
      {
        scale: 0.9,
        opacity: 0,
        filter: "blur(10px)",
        duration: 1,
        ease: "power2.inOut",
      },
      0
    );

    // Block 2 enters
    tl.fromTo(
      "#filter-block-2",
      { opacity: 0, y: 50, scale: 0.9, filter: "blur(6px)" },
      {
        opacity: 1,
        y: 0,
        scale: 1,
        filter: "blur(0px)",
        duration: 1,
        ease: "power2.inOut",
      },
      0.4
    );

    // --- State 2 → State 3: Block 2 out, Block 3 in ---

    // Block 2 blurs, shrinks, fades
    tl.to(
      "#filter-block-2",
      {
        scale: 0.9,
        opacity: 0,
        filter: "blur(10px)",
        duration: 1,
        ease: "power2.inOut",
      },
      1.8
    );

    // Block 3 enters
    tl.fromTo(
      "#filter-block-3",
      { opacity: 0, y: 50, scale: 0.9, filter: "blur(6px)" },
      {
        opacity: 1,
        y: 0,
        scale: 1,
        filter: "blur(0px)",
        duration: 1,
        ease: "power2.inOut",
      },
      2.2
    );
  });
</script>

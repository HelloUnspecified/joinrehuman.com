---
const people = [
  {
    name: "Sarah Jenkins",
    company: "Wavelength",
    transformation: 'Plugged a massive audience leak. Scaled from 0 to 600 active alumni and <strong class="font-bold text-[#121212] dark:text-[#EBE9E4]">added $700k ARR with $0 ad spend.</strong>',
    img: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=400&h=500&fit=crop&crop=faces",
  },
  {
    name: "Marcus Vance",
    company: "Archetype HQ",
    transformation: 'Transitioned from 100% outbound hustle to undeniable inbound authority. <strong class="font-bold text-[#121212] dark:text-[#EBE9E4]">Closed $250k in pipeline within 90 days.</strong>',
    img: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&h=500&fit=crop&crop=faces",
  },
  {
    name: "Elena Rostova",
    company: "NovaTech",
    transformation: 'Architected a self-sustaining ecosystem. Achieved 40% weekly active engagement with <strong class="font-bold text-[#121212] dark:text-[#EBE9E4]">60% of new enrollments driven by organic referrals.</strong>',
    img: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=400&h=500&fit=crop&crop=faces",
  },
  {
    name: "David Chen",
    company: "Basecamp Co.",
    transformation: 'Escaped the algorithm. Successfully migrated 15,000 passive followers into a <strong class="font-bold text-[#121212] dark:text-[#EBE9E4]">custom-architected Skool ecosystem with near-zero churn.</strong>',
    img: "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=400&h=500&fit=crop&crop=faces",
  },
];

const allCards = [...people, ...people, ...people];
---

<section class="bg-warm-light dark:bg-warm-dark min-h-screen flex flex-col justify-center py-32 px-6 md:px-10 overflow-hidden">
  <div class="mx-auto max-w-[1400px] w-full">
    <!-- System Header -->
    <div class="mb-12">
      <p class="font-mono text-xs uppercase tracking-widest text-ember">
        &gt; SYS.PROOF // THE_HUMANS
      </p>
    </div>

    <!-- Massive Text -->
    <h2 class="font-heading text-5xl md:text-7xl lg:text-8xl xl:text-[120px] font-black uppercase italic tracking-tight text-text-light dark:text-text-dark mb-20 leading-[0.9]">
      High-Tech<br />Humanist
    </h2>
  </div>

  <!-- Infinite Marquee Wrapper -->
  <div class="relative w-full overflow-hidden pt-6" id="marquee-wrapper">
    <!-- Left Edge Fade -->
    <div class="absolute left-0 top-0 bottom-0 w-24 md:w-40 z-10 bg-linear-to-r from-[#F9F8F6] dark:from-[#1A1918] to-transparent pointer-events-none"></div>
    <!-- Right Edge Fade -->
    <div class="absolute right-0 top-0 bottom-0 w-24 md:w-40 z-10 bg-linear-to-l from-[#F9F8F6] dark:from-[#1A1918] to-transparent pointer-events-none"></div>

    <!-- Scrolling Track -->
    <div
      id="marquee-track"
      class="flex items-stretch gap-8 w-max"
      style="animation: marquee-scroll 30s linear infinite;"
    >
      {allCards.map((person) => (
        <a href="#" class="group flex flex-col w-[360px] h-[580px] shrink-0 bg-white dark:bg-[#121212] p-6 rounded-[2rem] shadow-xl border border-black/5 dark:border-white/5 transition-all duration-500 hover:scale-105 hover:-translate-y-3 cursor-pointer">
          {/* Portrait */}
          <div class="relative w-full h-[280px] mb-6 shrink-0 overflow-hidden rounded-2xl">
            <img
              src={person.img}
              alt={person.name}
              class="absolute inset-0 w-full h-full object-cover grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700"
              loading="lazy"
            />
          </div>
          {/* Name */}
          <h4 class="font-heading font-black text-xl uppercase tracking-tight text-text-light dark:text-text-dark mb-1">
            {person.name}
          </h4>
          {/* Transformation */}
          <p class="text-sm text-text-light/50 dark:text-text-dark/50 mb-0" set:html={person.transformation}>
          </p>
          {/* Logo & CTA Footer */}
          <div class="mt-auto pt-6 border-t border-black/10 dark:border-white/10 flex items-center justify-between">
            <span class="font-mono text-xs uppercase tracking-widest text-[#121212]/50 dark:text-[#EBE9E4]/50 group-hover:text-[#FF5733] transition-colors duration-300">
              {person.company}
            </span>
            <span class="font-mono text-[#FF5733] text-xs uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all transform translate-x-[-10px] group-hover:translate-x-0 duration-300">View ↗</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  const wrapper = document.getElementById("marquee-wrapper");
  const track = document.getElementById("marquee-track");
  if (wrapper && track) {
    wrapper.addEventListener("mouseenter", () => {
      track.style.animationPlayState = "paused";
    });
    wrapper.addEventListener("mouseleave", () => {
      track.style.animationPlayState = "running";
    });
  }
</script>

---
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-[100] transition-all duration-300"
>
  <div class="mx-auto flex max-w-[1400px] items-center justify-between px-6 py-5 md:px-10">
    <!-- Brand -->
    <a href="/" class="font-heading text-2xl font-black uppercase italic tracking-tight text-text-light dark:text-text-dark">
      re/Human
    </a>

    <!-- Right Side -->
    <div class="flex items-center gap-4">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="font-mono text-xs tracking-wider text-text-light/60 dark:text-text-dark/60 hover:text-ember transition-colors cursor-pointer"
        aria-label="Toggle theme"
      >
        [<span id="toggle-label">LGT / <span class="text-ember font-bold">DRK</span></span>]
      </button>

      <!-- CTA -->
      <a
        href="#newsletter"
        class="group relative inline-flex items-center gap-2 bg-ember px-5 py-2.5 font-mono text-xs font-bold uppercase tracking-wider text-white transition-transform duration-200 hover:scale-[1.03]"
      >
        Enter re/Human
      </a>
    </div>
  </div>
</nav>

<script>
  // Theme toggle logic
  const toggle = document.getElementById("theme-toggle");
  const label = document.getElementById("toggle-label");

  function updateLabel() {
    const isDark = document.documentElement.classList.contains("dark");
    if (label) {
      if (isDark) {
        label.innerHTML = `<span class="text-ember font-bold">LGT</span> / DRK`;
      } else {
        label.innerHTML = `LGT / <span class="text-ember font-bold">DRK</span>`;
      }
    }
  }

  updateLabel();

  toggle?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("rh-theme", isDark ? "dark" : "light");
    updateLabel();
  });

  // Navbar backdrop blur on scroll
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      navbar?.classList.add("backdrop-blur-xl", "bg-warm-light/80", "dark:bg-warm-dark/80");
    } else {
      navbar?.classList.remove("backdrop-blur-xl", "bg-warm-light/80", "dark:bg-warm-dark/80");
    }
  });
</script>

---
---

<section class="relative min-h-screen flex items-center bg-warm-dark px-6 md:px-10 py-32">
  <div class="mx-auto max-w-[1400px] w-full">
    <!-- System Header -->
    <div class="mb-12">
      <p class="font-mono text-xs uppercase tracking-widest text-ember">
        &gt; SYS.OVERRIDE // THE_PARADIGM_SHIFT
      </p>
    </div>

    <!-- Content -->
    <div class="max-w-5xl">
      <h2 class="manifesto-reveal font-heading text-5xl md:text-7xl lg:text-8xl xl:text-[110px] font-black uppercase italic tracking-tight leading-[0.9] text-text-dark mb-12">
        Humans are<br />the real infrastructure.
      </h2>
      <p class="manifesto-reveal text-lg md:text-xl text-text-dark/60 leading-relaxed max-w-2xl">
        The industry is obsessed with scaling noise, hacking algorithms, and automating relationships. We architect the exact opposite. Merging 25 years of software engineering with the experience of running one of the largest community conferences in the US, we build digital ecosystems that prove a simple truth: <strong class="font-bold text-[#EBE9E4]">When we connect, we build faster. When we trust, we create braver things. When we belong, we stay.</strong>
      </p>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(
    ".manifesto-reveal",
    { opacity: 0, y: 60 },
    {
      opacity: 1,
      y: 0,
      duration: 1.2,
      stagger: 0.3,
      ease: "power3.out",
      scrollTrigger: {
        trigger: ".manifesto-reveal",
        start: "top 80%",
      },
    }
  );
</script>

---
const audiencePoints = [
  "The \"8th-Grade Dance\" Dynamic",
  "Hunting for Outbound Clients",
  "Dependency on Algorithms",
  "High Churn, Low LTV",
];

const communityPoints = [
  "Peer-to-Peer Facilitation",
  "Inbound, Undeniable Authority",
  "Platform Agnostic Ecosystems",
  "Fierce, Self-Sustaining Loyalty",
];
---

<section class="py-32 md:py-48 px-6 md:px-10" id="dichotomy-section">
  <!-- Terminal Header -->
  <div class="w-full flex justify-center items-center mb-8">
    <h2 class="font-mono text-xs md:text-sm uppercase tracking-widest text-rh-ink/50 dark:text-rh-chalk/50 flex items-center">
      &gt; SYS.ANALYSIS // THE_DICHOTOMY
    </h2>
  </div>

  <!-- Massive Header -->
  <div class="mx-auto max-w-[1400px] mb-16 md:mb-24 text-center">
    <h2 class="dichotomy-header font-heading text-6xl md:text-8xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-ink dark:text-rh-chalk">
      Crowd vs.Culture.
    </h2>
  </div>

  <!-- The Split Screen -->
  <div class="mx-auto max-w-[1400px]" id="dichotomy-split">
    <div class="flex flex-col md:flex-row min-h-[60vh] md:items-stretch">
      <!-- LEFT: The Algorithmic Audience -->
      <div class="dichotomy-col flex-1 flex flex-col justify-start bg-rh-warm-light p-12 md:p-24">
        <p class="font-mono text-xs md:text-sm uppercase tracking-widest text-rh-ink/50 dark:text-rh-chalk/50 flex items-center mb-16">
          &gt; SYS.ERROR // THE AUDIENCE
        </p>
        <ul class="space-y-16">
          {audiencePoints.map((point) => (
            <li class="old-paradigm-item">
              <span class="font-heading text-3xl md:text-4xl font-black uppercase tracking-normal text-rh-ink/50 leading-none line-through decoration-rh-ink/30">
                {point}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- RIGHT: The re/Human Community -->
      <div class="dichotomy-col flex-1 flex flex-col justify-start bg-rh-warm-dark p-12 md:p-24">
        <p class="font-mono text-xs md:text-sm uppercase tracking-widest text-rh-chalk/50 flex items-center mb-16">
          <span class="inline-block w-2 h-2 rounded-full bg-rh-ember animate-pulse mr-2 align-middle"></span>
          SYS.ACTIVE // THE COMMUNITY
        </p>
        <ul class="space-y-16">
          {communityPoints.map((point) => (
            <li class="new-paradigm-item">
              <span class="font-heading text-3xl md:text-4xl font-black uppercase tracking-normal text-rh-chalk leading-none">
                {point}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

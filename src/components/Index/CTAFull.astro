---
import SectionLabel from "../../elements/SectionLabel.astro";
import Heading from "../../elements/Heading.astro";
import BodyText from "../../elements/BodyText.astro";
---

<section
  class="bg-rh-warm-light dark:bg-rh-warm-dark py-32 md:py-48 px-6 md:px-10"
  id="cta-full-section"
>
  <div class="mx-auto w-full max-w-[1400px]">
    <!-- Terminal Header -->
    <div class="cta-full-reveal mb-10">
      <SectionLabel text="> SYS.ROUTE // DECISION_TREE" />
    </div>

    <!-- Headline -->
    <Heading class="cta-full-reveal mb-6 max-w-4xl">
      What's your <span class="text-rh-ember">current state?</span>
    </Heading>

    <!-- Context -->
    <BodyText class="cta-full-reveal max-w-2xl mb-20">
      Every organization is at a different point. The right next step depends on
      where you are right now, not where you think you should be.
    </BodyText>

    <!-- Decision tree flowchart -->
    <div class="max-w-5xl mx-auto" id="decision-tree">
      <!-- Root node -->
      <div class="cta-full-reveal flex justify-center mb-0">
        <div
          class="route-root inline-flex items-center gap-3 border border-rh-ink/20 dark:border-rh-chalk/20 px-6 py-3 font-mono text-xs md:text-sm uppercase tracking-widest text-rh-ink/50 dark:text-rh-chalk/50"
        >
          <span class="w-2 h-2 rounded-full bg-rh-ember animate-pulse"
          ></span>
          SELECT CURRENT_STATE
        </div>
      </div>

      <!-- Trunk line -->
      <div class="flex justify-center">
        <div
          id="route-trunk"
          class="w-px h-10 bg-rh-ink/10 dark:bg-rh-chalk/10 transition-colors duration-300"
        >
        </div>
      </div>

      <!-- Horizontal connector + branch lines -->
      <div class="route-branches relative">
        <!-- Horizontal line segments (hidden on mobile) -->
        <div class="route-grid grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
          <!-- Left segment: col1-center to col2-center -->
          <div
            id="route-line-left"
            class="hidden md:block absolute top-0 h-px bg-rh-ink/10 dark:bg-rh-chalk/10 transition-colors duration-300 z-10"
            style="left: calc((100% - 2 * 2rem) / 6); right: 50%;"
          ></div>
          <!-- Right segment: col2-center to col3-center -->
          <div
            id="route-line-right"
            class="hidden md:block absolute top-0 h-px bg-rh-ink/10 dark:bg-rh-chalk/10 transition-colors duration-300 z-10"
            style="left: 50%; right: calc((100% - 2 * 2rem) / 6);"
          ></div>
          <!-- Branch 1 — Book (primary) -->
          <a href="/book" class="route-node group flex flex-col items-center" data-branch>
            <!-- Vertical drop line -->
            <div
              class="hidden md:block w-px h-8 bg-rh-ink/10 dark:bg-rh-chalk/10 group-hover:bg-rh-ember transition-colors duration-300"
            >
            </div>
            <!-- Node dot -->
            <div
              class="w-3 h-3 rounded-full border-2 border-rh-ember bg-rh-warm-light dark:bg-rh-warm-dark group-hover:bg-rh-ember transition-colors duration-300 mb-5 shrink-0"
            >
            </div>
            <!-- Card -->
            <div
              class="w-full flex-1 flex flex-col border border-rh-ember/30 group-hover:border-rh-ember p-6 md:p-8 transition-all duration-300 group-hover:shadow-lg group-hover:shadow-rh-ember/5 text-center"
            >
              <div
                class="font-mono text-[10px] uppercase tracking-widest text-rh-ember mb-4"
              >
                PRIORITY: HIGH
              </div>
              <p
                class="text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 group-hover:text-rh-ink/80 dark:group-hover:text-rh-chalk/80 transition-colors duration-300 leading-relaxed flex-1"
              >
                I know something's broken. People are leaving, engagement is
                flat, and the fixes we've tried haven't held.
              </p>
              <span
                class="inline-block font-mono text-sm md:text-base uppercase tracking-widest text-rh-ember group-hover:scale-105 transition-transform duration-300 mt-5"
              >
                Book the Review →
              </span>
            </div>
          </a>

          <!-- Branch 2 — Diagnostic -->
          <a
            href="/diagnostic"
            class="route-node group flex flex-col items-center"
            data-branch
          >
            <div
              class="hidden md:block w-px h-8 bg-rh-ink/10 dark:bg-rh-chalk/10 group-hover:bg-rh-ember transition-colors duration-300"
            >
            </div>
            <div
              class="w-3 h-3 rounded-full border-2 border-rh-ink/20 dark:border-rh-chalk/20 bg-rh-warm-light dark:bg-rh-warm-dark group-hover:border-rh-ember group-hover:bg-rh-ember transition-colors duration-300 mb-5 shrink-0"
            >
            </div>
            <div
              class="w-full flex-1 flex flex-col border border-rh-ink/10 dark:border-rh-chalk/10 group-hover:border-rh-ember/50 p-6 md:p-8 transition-all duration-300 group-hover:shadow-lg group-hover:shadow-rh-ember/5 text-center"
            >
              <div
                class="font-mono text-[10px] uppercase tracking-widest text-rh-ink/30 dark:text-rh-chalk/30 mb-4"
              >
                PRIORITY: MEDIUM
              </div>
              <p
                class="text-sm md:text-base text-rh-ink/50 dark:text-rh-chalk/50 group-hover:text-rh-ink/70 dark:group-hover:text-rh-chalk/70 transition-colors duration-300 leading-relaxed flex-1"
              >
                Something feels off but I'm not sure what. I want to understand
                where the gaps are before I talk to anyone.
              </p>
              <span
                class="inline-block font-mono text-sm md:text-base uppercase tracking-widest text-rh-ember group-hover:scale-105 transition-transform duration-300 mt-5"
              >
                Run the Diagnostic →
              </span>
            </div>
          </a>

          <!-- Branch 3 — Subscribe -->
          <a
            href="#subscribe"
            class="route-node group flex flex-col items-center"
            data-branch
          >
            <div
              class="hidden md:block w-px h-8 bg-rh-ink/10 dark:bg-rh-chalk/10 group-hover:bg-rh-ember transition-colors duration-300"
            >
            </div>
            <div
              class="w-3 h-3 rounded-full border-2 border-rh-ink/10 dark:border-rh-chalk/10 bg-rh-warm-light dark:bg-rh-warm-dark group-hover:border-rh-ember group-hover:bg-rh-ember transition-colors duration-300 mb-5 shrink-0"
            >
            </div>
            <div
              class="w-full flex-1 flex flex-col border border-rh-ink/5 dark:border-rh-chalk/5 group-hover:border-rh-ember/30 p-6 md:p-8 transition-all duration-300 group-hover:shadow-lg group-hover:shadow-rh-ember/5 text-center"
            >
              <div
                class="font-mono text-[10px] uppercase tracking-widest text-rh-ink/20 dark:text-rh-chalk/20 mb-4"
              >
                PRIORITY: LOW
              </div>
              <p
                class="text-sm md:text-base text-rh-ink/40 dark:text-rh-chalk/40 group-hover:text-rh-ink/60 dark:group-hover:text-rh-chalk/60 transition-colors duration-300 leading-relaxed flex-1"
              >
                I'm just paying attention. I want to understand human
                architecture before I need it.
              </p>
              <span
                class="inline-block font-mono text-xs md:text-sm uppercase tracking-widest text-rh-ink/30 dark:text-rh-chalk/30 group-hover:text-rh-ember transition-colors duration-300 mt-5"
              >
                Subscribe to the Manual →
              </span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /*
   * Horizontal connector bar.
   * 3-col grid: each column is 1fr with gap between.
   * Column centers sit at 1/6, 1/2, 5/6 of total grid width
   * but gap shifts the outer columns inward.
   * Using the grid container (route-grid) so we can rely on
   * its actual width. The bar sits at top:0 of the grid,
   * spanning 50% of col-1 to 50% of col-3.
   */
  .route-grid {
    position: relative;
  }

</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(
    ".cta-full-reveal",
    { opacity: 0, y: 50 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.25,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#cta-full-section",
        start: "top 70%",
      },
    },
  );

  gsap.fromTo(
    ".route-node",
    { opacity: 0, y: 30 },
    {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.2,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#decision-tree",
        start: "top 60%",
      },
    },
  );

  // Highlight path segments based on which branch is hovered
  const trunk = document.getElementById("route-trunk");
  const lineLeft = document.getElementById("route-line-left");
  const lineRight = document.getElementById("route-line-right");
  const branches = document.querySelectorAll("[data-branch]");

  branches.forEach((branch, index) => {
    branch.addEventListener("mouseenter", () => {
      trunk?.classList.add("!bg-rh-ember");
      // Left branch (index 0): light up left segment only
      // Center branch (index 1): no horizontal segments needed
      // Right branch (index 2): light up right segment only
      if (index === 0) {
        lineLeft?.classList.add("!bg-rh-ember");
      } else if (index === 1) {
        // Center — trunk goes straight down, no horizontal needed
      } else if (index === 2) {
        lineRight?.classList.add("!bg-rh-ember");
      }
    });
    branch.addEventListener("mouseleave", () => {
      trunk?.classList.remove("!bg-rh-ember");
      lineLeft?.classList.remove("!bg-rh-ember");
      lineRight?.classList.remove("!bg-rh-ember");
    });
  });
</script>

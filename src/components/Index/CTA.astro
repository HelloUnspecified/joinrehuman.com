---
import SectionLabel from "../../elements/SectionLabel.astro";
import CTAButton from "../../elements/CTAButton.astro";
---

<section
  class="py-28 md:py-40 flex flex-col items-center justify-center text-center px-6 bg-rh-warm-light dark:bg-rh-warm-dark"
>
  <!-- Terminal Header -->
  <SectionLabel text="> SYS.INITIATE // ENGAGEMENT" />

  <!-- Headline -->
  <h2
    class="font-heading text-6xl md:text-8xl font-black uppercase italic tracking-tight leading-[1.1] text-rh-ink dark:text-rh-chalk mt-8 mb-12"
  >
    Start Building<br />The Architecture.
  </h2>

  <!-- CTA Button -->
  <CTAButton href="/book">BOOK_ARCHITECTURE_REVIEW</CTAButton>

  <p
    class="font-mono text-sm text-rh-ink/40 dark:text-rh-chalk/40 mt-6"
  >
    Not ready yet?
    <a href="#subscribe" class="text-rh-ember hover:underline"
      >Subscribe to the Manual</a
    >
  </p>
</section>

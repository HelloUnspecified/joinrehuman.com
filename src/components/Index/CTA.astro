---
import SectionLabel from "../../elements/SectionLabel.astro";
import CTAButton from "../../elements/CTAButton.astro";
---

<section
  class="py-32 md:py-48 flex flex-col items-center justify-center text-center px-6 bg-rh-warm-light dark:bg-rh-warm-dark"
>
  <!-- Terminal Header -->
  <SectionLabel text="> SYS.INITIATE // ENGAGEMENT" />

  <!-- Headline -->
  <h2
    class="font-heading text-6xl md:text-8xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-ink dark:text-rh-chalk mt-8 mb-12"
  >
    Start Building<br />Your Moat.
  </h2>

  <!-- CTA Button -->
  <CTAButton href="/book">BOOK_STRATEGY_REVIEW</CTAButton>
</section>

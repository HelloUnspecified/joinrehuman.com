---
---

<section class="relative flex min-h-[100dvh] items-center overflow-hidden bg-rh-warm-light dark:bg-rh-warm-dark">
  <!-- Background Grid/Code Stream -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden opacity-[0.04] dark:opacity-[0.06]">
    <div class="font-mono text-[10px] leading-[1.8] text-rh-ink dark:text-rh-chalk whitespace-pre select-none" id="hero-grid" aria-hidden="true"></div>
  </div>

  <div class="relative z-10 mx-auto w-full max-w-[1400px] px-6 md:px-10 pt-32 pb-20">
    <!-- System Header -->
    <div class="hero-fade mb-8">
      <p class="font-mono text-xs md:text-sm uppercase tracking-widest text-rh-ink/50 dark:text-rh-chalk/50 flex items-center">
        <span class="inline-block w-2 h-2 rounded-full bg-rh-ember animate-pulse mr-2 align-middle"></span>
        SYS.CORE // ONLINE
      </p>
    </div>

    <!-- Headline -->
    <h1 class="hero-fade font-heading text-5xl md:text-7xl lg:text-8xl xl:text-[120px] font-black uppercase italic tracking-normal leading-[1.1] text-rh-ink dark:text-rh-chalk mb-8">
      Community<br />is the new<br />moat.
    </h1>

    <!-- Subheadline -->
    <p class="hero-fade max-w-2xl text-lg md:text-xl text-rh-ink/70 dark:text-rh-chalk/70 leading-relaxed">
      Whether you are invisible in a crowded market, or bleeding a massive audience out the back door, content is no longer enough. 
      
      <br/>
      <br/>
      Stop renting attention.
      
      <br/>
      <br/>
      Start architecting a movement.
    </p>

    <!-- Scroll Indicator -->
    <div class="hero-fade mt-16 md:mt-24">
      <div class="flex items-center gap-3 font-mono text-xs text-rh-ink/30 dark:text-rh-chalk/30 uppercase tracking-widest">
        <span class="block h-8 w-px bg-rh-ember/50"></span>
        Scroll to explore
        <span class="inline-block w-2.5 h-4 md:h-5 bg-rh-ember animate-pulse"></span>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  // Generate background grid
  const grid = document.getElementById("hero-grid");
  if (grid) {
    const lines: string[] = [];
    const tokens = [
      "HUMAN_PROTOCOL", "INIT_SYSTEM", "CONNECT.AUTH", "BUILD_MOAT",
      "SOUL.RENDER", "CULTURE.SYNC", "TRUST_LAYER", "COMMUNITY.BIND",
      "SIGNAL.BOOST", "EMPATHY_ENGINE", "SCALE.HUMAN", "DATA.HEART"
    ];
    for (let i = 0; i < 110; i++) {
      const line = Array.from({ length: 16 }, () =>
        tokens[Math.floor(Math.random() * tokens.length)]
      ).join("  ");
      lines.push(line);
    }
    grid.textContent = lines.join("\n");

    // Slow upward drift animation
    gsap.to(grid, {
      yPercent: -15,
      duration: 60,
      ease: "none",
      repeat: -1,
    });
  }

  // GSAP staggered fade-up
  gsap.fromTo(
    ".hero-fade",
    { opacity: 0, y: 40 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.2,
      ease: "power3.out",
      delay: 0.3,
    }
  );
</script>

---
---

<section class="relative min-h-screen flex flex-col justify-center items-center w-full px-6 bg-rh-warm-light dark:bg-rh-warm-dark overflow-hidden" id="filter-section">
  <!-- Centered Terminal Header — in normal flow above text -->
  <div class="w-full text-center mb-16">
    <p class="font-mono text-xs md:text-sm uppercase tracking-widest text-rh-ink/50 dark:text-rh-chalk/50 flex items-center justify-center">
      &gt; SYS.FIREWALL // QUALIFICATION_CHECK
    </p>
  </div>

  <!-- Text Block Wrapper — fixed height, holds all 3 blocks -->
  <div class="relative w-full max-w-5xl mx-auto text-center h-[50vh] md:h-[40vh] flex items-center justify-center">
    <!-- Block 1: The Rejection -->
    <div id="filter-block-1" class="absolute top-0 left-0 w-full h-full flex flex-col justify-center items-center px-4">
      <p class="text-2xl md:text-3xl lg:text-4xl text-rh-ink/70 dark:text-rh-chalk/70 leading-tight md:leading-snug font-medium mb-8 max-w-4xl mx-auto tracking-tight">
        If you want to hack algorithms, spam DMs, or build a temporary Discord just to upsell a course...
      </p>
      <button
        onclick="window.close(); if(!window.closed) window.location.href='about:blank';"
        class="inline-block mt-8 px-8 py-4 border-4 border-rh-ink dark:border-rh-chalk text-rh-ink dark:text-rh-chalk font-heading text-xl md:text-2xl font-black uppercase italic tracking-tighter hover:bg-rh-ink hover:text-rh-warm-light dark:hover:bg-rh-chalk dark:hover:text-rh-warm-dark transition-colors cursor-pointer underline decoration-4 underline-offset-8"
      >
        Close This Tab.
      </button>
    </div>

    <!-- Block 2: The Acceptance -->
    <div id="filter-block-2" class="absolute top-0 left-0 w-full h-full flex flex-col justify-center items-center px-4 opacity-0 pointer-events-none">
      <p class="text-2xl md:text-3xl lg:text-4xl text-rh-ink/70 dark:text-rh-chalk/70 leading-tight md:leading-snug font-medium mb-8 max-w-4xl mx-auto tracking-tight">
        If you want to translate your raw expertise into a self-sustaining ecosystem, where your people defend your mission in rooms you aren't even in.
      </p>
      <p class="font-heading text-5xl md:text-7xl font-black uppercase tracking-normal italic leading-none text-rh-ember">
        You belong here.
      </p>
    </div>

    <!-- Block 3: The Invitation -->
    <div id="filter-block-3" class="absolute top-0 left-0 w-full h-full flex flex-col justify-center items-center px-4 opacity-0 pointer-events-none">
      <p class="text-2xl md:text-3xl lg:text-4xl text-rh-ink/70 dark:text-rh-chalk/70 leading-tight md:leading-snug font-medium mb-8 max-w-4xl mx-auto tracking-tight">
        Because a massive audience without culture is just a room full of strangers.
      </p>
      <p class="font-heading text-5xl md:text-7xl font-black uppercase tracking-normal italic leading-none text-rh-ember mt-6">
        We architect belonging.
      </p>
      <p class="font-heading text-2xl uppercase italic tracking-tighter text-rh-ink/50 dark:text-rh-chalk/50 mt-8">
        Welcome to the family.
      </p>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.context(() => {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#filter-section",
        start: "top top",
        end: "+=300%",
        scrub: 1,
        pin: true,
      },
    });

    // --- State 1 → State 2: Block 1 out, Block 2 in ---

    // Block 1 blurs, shrinks, fades
    tl.to(
      "#filter-block-1",
      {
        scale: 0.9,
        opacity: 0,
        filter: "blur(10px)",
        pointerEvents: "none",
        duration: 1,
        ease: "power2.inOut",
      },
      0
    );

    // Block 2 enters
    tl.fromTo(
      "#filter-block-2",
      { opacity: 0, y: 50, scale: 0.9, filter: "blur(6px)", pointerEvents: "none" },
      {
        opacity: 1,
        y: 0,
        scale: 1,
        filter: "blur(0px)",
        pointerEvents: "auto",
        duration: 1,
        ease: "power2.inOut",
      },
      0.4
    );

    // --- State 2 → State 3: Block 2 out, Block 3 in ---

    // Block 2 blurs, shrinks, fades
    tl.to(
      "#filter-block-2",
      {
        scale: 0.9,
        opacity: 0,
        filter: "blur(10px)",
        pointerEvents: "none",
        duration: 1,
        ease: "power2.inOut",
      },
      1.8
    );

    // Block 3 enters
    tl.fromTo(
      "#filter-block-3",
      { opacity: 0, y: 50, scale: 0.9, filter: "blur(6px)", pointerEvents: "none" },
      {
        opacity: 1,
        y: 0,
        scale: 1,
        filter: "blur(0px)",
        pointerEvents: "auto",
        duration: 1,
        ease: "power2.inOut",
      },
      2.2
    );
  });
</script>

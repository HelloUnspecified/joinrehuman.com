---
import SectionLabel from "../../elements/SectionLabel.astro";
import Heading from "../../elements/Heading.astro";
import BodyText from "../../elements/BodyText.astro";
---

<section
  class="bg-rh-warm-light dark:bg-rh-warm-dark py-32 md:py-48 px-6 md:px-10"
  id="diagnostic-section"
>
  <div class="mx-auto w-full max-w-[1400px]">
    <!-- Terminal Header -->
    <div class="diagnostic-reveal mb-10">
      <SectionLabel text="> SYS.DIAGNOSTIC // STATUS_CRITICAL" />
    </div>

    <!-- Headline -->
    <Heading class="diagnostic-reveal mb-12 max-w-5xl tracking-tight">
      AI is reshaping how we work.
      <span class="text-rh-ember">Nobody is redesigning how we connect.</span>
    </Heading>

    <!-- The shift -->
    <div class="diagnostic-reveal max-w-3xl mb-14">
      <BodyText class="mb-6">
        AI is compressing teams. Automating knowledge work. Eliminating the
        roles that quietly held organizations together. The people who carried
        culture, built trust, and connected humans to each other.
      </BodyText>
    </div>
    
    <!-- The symptoms -->
    <div class="max-w-3xl space-y-4 mb-16">
      <p
        class="font-mono text-sm md:text-base text-rh-ink/50 dark:text-rh-chalk/50 leading-relaxed"
      >
        The tasks are being replaced. The connective tissue is not.
      </p>
      <p
        class="diagnostic-line font-mono text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
      >
        <span class="text-rh-ember/70 mr-2">▸</span> You're feeling it. Your
        people leave.
      </p>
      <p
        class="diagnostic-line font-mono text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
      >
        <span class="text-rh-ember/70 mr-2">▸</span> Your community is quiet.
        Your culture doesn't scale.
      </p>
      <p
        class="diagnostic-line font-mono text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
      >
        <span class="text-rh-ember/70 mr-2">▸</span> Customers buy but don't
        stay.
      </p>
    </div>

    <!-- The failed attempts -->
    <div class="diagnostic-reveal max-w-3xl">
      <BodyText class="mb-6">
        You've rebranded. Switched platforms. Hired agencies.
      </BodyText>
      <p
        class="text-xl md:text-2xl font-heading font-black uppercase italic text-rh-ink dark:text-rh-chalk leading-tight"
      >
        None of it held. <br/><br/>Because none of it was the disease.
      </p>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(
    ".diagnostic-reveal",
    { opacity: 0, y: 50 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.3,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#diagnostic-section",
        start: "top 70%",
      },
    },
  );

  gsap.fromTo(
    ".diagnostic-line",
    { opacity: 0, x: -20 },
    {
      opacity: 1,
      x: 0,
      duration: 0.6,
      stagger: 0.15,
      ease: "power2.out",
      scrollTrigger: {
        trigger: "#diagnostic-section",
        start: "top 55%",
      },
    },
  );
</script>

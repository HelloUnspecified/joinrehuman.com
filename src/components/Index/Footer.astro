---
import SectionLabel from "../../elements/SectionLabel.astro";
---

<footer
  class="bg-rh-warm-dark text-rh-chalk pt-32 pb-12 px-6 md:px-12 lg:px-16 rounded-t-[4rem] mt-24 border-t border-white/10"
>
  <div class="mx-auto max-w-[1400px]">
    <!-- Brand Row -->
    <div class="mb-24">
      <a
        href="/"
        class="font-heading font-black text-3xl md:text-4xl tracking-tighter text-rh-chalk uppercase italic hover:text-rh-ember transition-colors duration-300"
      >
        re/<span class="text-rh-ember">Human</span>
      </a>
    </div>

    <!-- Newsletter + Terminal Row -->
    <div
      class="flex flex-col lg:flex-row justify-between items-start gap-12 lg:gap-16 mb-0"
    >
      <!-- Left: Newsletter Section -->
      <div class="flex-1">
        <!-- Terminal Header -->
        <SectionLabel
          text="> SYS.ARCHIVE // LONG_FORM"
          class="!text-rh-chalk/50"
        />

        <!-- Headline -->
        <h2
          class="font-heading text-5xl md:text-7xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-chalk mt-6"
        >
          Read the Manual.
        </h2>

        <!-- Body -->
        <p
          class="text-lg md:text-xl text-rh-chalk/70 leading-relaxed max-w-2xl mt-4 mb-12"
        >
          Get our weekly dispatch on community architecture, frameworks, case
          studies, and systems thinking for leaders building movements.
        </p>

        <!-- Email Input -->
        <form id="newsletter-form" class="max-w-2xl">
          <div class="flex flex-col md:flex-row gap-4">
            <input
              type="email"
              name="email"
              id="email-input"
              required
              data-1p-ignore
              autocomplete="off"
              placeholder="[ awaiting_input: user@domain.com ]"
              class="text-sm bg-transparent border-b-2 border-rh-chalk/30 text-rh-chalk px-4 py-4 focus:outline-none focus:border-rh-ember transition-colors w-full font-mono placeholder:text-rh-chalk/30"
            />
            <button
              type="submit"
              class="font-mono text-sm uppercase tracking-widest text-rh-ember px-8 py-4 border border-transparent hover:border-rh-ember transition-colors shrink-0"
            >
              [ INITIATE_PROTOCOL ]
            </button>
          </div>
          <p id="form-message" class="mt-6"></p>
        </form>
      </div>

      <!-- Right: Terminal Window -->
      <div
        class="w-full max-w-full lg:w-auto lg:min-w-[380px] bg-rh-ink border border-rh-chalk/10 rounded-xl overflow-hidden self-start"
      >
        <!-- Title Bar -->
        <div
          class="flex items-center justify-between px-4 py-3 border-b border-rh-chalk/10"
        >
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-rh-ember/60"></span>
            <span class="w-3 h-3 rounded-full bg-rh-chalk/20"></span>
            <span class="w-3 h-3 rounded-full bg-rh-chalk/20"></span>
          </div>
          <span
            class="font-mono text-[10px] uppercase tracking-widest text-rh-chalk/30"
            >rehuman_nav.sh</span
          >
        </div>
        <!-- Terminal Body -->
        <div
          class="px-4 md:px-5 py-4 font-mono text-xs md:text-sm space-y-2 overflow-x-auto"
        >
          <!-- MOTD ASCII Art -->
          <div
            class="text-rh-ember/40 text-[9px] md:text-[10px] leading-tight mb-3"
          >
            <pre
              class="whitespace-pre overflow-x-auto">╦═╗╔═╗  ╱ ╦ ╦╦ ╦╔╦╗╔═╗╔╗╔
╠╦╝║╣  ╱  ╠═╣║ ║║║║╠═╣║║║
╩╚═╚═╝╱   ╩ ╩╚═╝╩ ╩╩ ╩╝╚╝</pre>
            <p class="text-rh-chalk/20 mt-1">
              v2.0.26 // human protocol active
            </p>
          </div>
          <p class="text-rh-ember/60 text-[10px] mb-1">select a destination:</p>
          <p class="text-rh-chalk/50">&gt; ls -la /sitemap</p>
          <div class="pl-4 space-y-1">
            <a
              href="https://blog.joinrehuman.com/"
              class="block text-rh-chalk/70 hover:text-rh-ember transition-colors"
              >drwxr-xr-x articles/</a
            >
            <a
              href="/book"
              class="block text-rh-chalk/70 hover:text-rh-ember transition-colors"
              >-rwxr-xr-x book_session</a
            >
            <a
              href="/the-architect"
              class="block text-rh-chalk/70 hover:text-rh-ember transition-colors"
              >-rw-r--r-- the_architect</a
            >
            <a
              href="mailto:hello@joinrehuman.com"
              class="block text-rh-chalk/70 hover:text-rh-ember transition-colors"
              >-rw-r--r-- contact</a
            >
          </div>
          <p class="text-rh-chalk/50 flex items-center pt-1">
            &gt;&nbsp;&nbsp;<a
              href="/book"
              class="text-green-400 hover:underline">BOOK_STRATEGY_CALL</a
            ><span
              class="inline-block w-[2px] h-[1em] bg-rh-ember ml-1 animate-pulse"
            ></span>
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom Row: Copyright -->
    <div
      class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mt-32 pt-8 border-t border-white/10 font-mono text-[10px] md:text-xs uppercase tracking-widest text-rh-chalk/50"
    >
      <span class="flex items-center gap-2 text-rh-ember">
        <span class="w-2 h-2 rounded-full bg-rh-ember animate-pulse"></span>
        HUMAN PROTOCOL // ACTIVE
      </span>
      <span
        >&copy; {new Date().getFullYear()} RE/HUMAN. ALL RIGHTS RESERVED.</span
      >
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById("newsletter-form");
  const messageElement = document.getElementById(
    "form-message",
  ) as HTMLParagraphElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const emailInput = document.getElementById(
      "email-input",
    ) as HTMLInputElement;
    const submitButton = form.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement;
    const email = emailInput.value;

    // Set loading state
    emailInput.disabled = true;
    submitButton.disabled = true;
    const originalButtonText = submitButton.textContent;
    submitButton.textContent = "[ TRANSMITTING... ]";
    submitButton.classList.add("animate-pulse", "opacity-50");
    messageElement.textContent = "";

    try {
      const response = await fetch("/api/subscribe", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ email }),
      });

      const data = await response.json();

      if (response.ok) {
        messageElement.textContent =
          "[ PROTOCOL_INITIATED ] Check your inbox to confirm your subscription.";
        messageElement.className = "mt-6 font-mono text-sm text-rh-ember";
        emailInput.value = "";
      } else {
        messageElement.textContent = `[ ERROR ] ${data.error || "Transmission failed. Try again."}`;
        messageElement.className = "mt-6 font-mono text-sm text-red-400";
      }
    } catch (error) {
      messageElement.textContent =
        "[ CONNECTION_LOST ] Network error. Please retry.";
      messageElement.className = "mt-6 font-mono text-sm text-red-400";
    } finally {
      emailInput.disabled = false;
      submitButton.disabled = false;
      submitButton.textContent = originalButtonText;
      submitButton.classList.remove("animate-pulse", "opacity-50");
    }
  });
</script>

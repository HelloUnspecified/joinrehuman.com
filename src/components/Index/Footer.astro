---
---

<footer class="bg-[#1A1918] text-[#EBE9E4] pt-32 pb-12 px-6 rounded-t-[4rem] mt-24 border-t border-white/10">
  <div class="mx-auto max-w-[1400px]">
    <!-- Brand & CTA Row -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-24 gap-8">
      <!-- Left: Logo -->
      <a href="/" class="font-heading font-black text-3xl md:text-4xl tracking-tighter text-[#EBE9E4] uppercase italic hover:text-[#FF5733] transition-colors duration-300">
        re/<span class="text-[#FF5733]">Human</span>
      </a>

      <!-- Right: Status & CTA -->
      <div class="flex flex-col items-end gap-3">
        <span class="flex items-center gap-2 font-mono text-[10px] md:text-xs uppercase tracking-widest text-[#FF5733]">
          <span class="w-2 h-2 rounded-full bg-[#FF5733] animate-pulse"></span>
          HUMAN PROTOCOL // ACTIVE
        </span>
        <a href="/book" class="font-mono text-sm text-[#EBE9E4]/70 hover:text-[#FF5733] transition-colors duration-300 flex items-center">
          &gt; DEPLOY_ARCHITECTURE<span class="inline-block w-[2px] h-[1em] bg-[#FF5733] ml-1 animate-pulse"></span>
        </a>
      </div>
    </div>

    <!-- Newsletter Section -->
    <div class="mb-0">
      <!-- Terminal Header -->
      <p class="font-mono text-xs md:text-sm uppercase tracking-widest text-[#EBE9E4]/50 flex items-center">
        &gt; SYS.ARCHIVE // LONG_FORM
      </p>

      <!-- Headline -->
      <h2 class="font-heading text-5xl md:text-7xl font-black uppercase italic tracking-normal leading-[1.1] text-[#EBE9E4] mt-6">
        Read the Manual.
      </h2>

      <!-- Body -->
      <p class="text-lg md:text-xl text-[#EBE9E4]/70 leading-relaxed max-w-2xl mt-4 mb-12">
        Join our dispatch for deep dives into culture design and community architecture.
      </p>

      <!-- Email Input -->
      <form class="flex flex-col md:flex-row max-w-2xl gap-4">
        <input
          type="email"
          placeholder="[ awaiting_input: user@domain.com ]"
          class="text-sm bg-transparent border-b-2 border-[#EBE9E4]/30 text-[#EBE9E4] px-4 py-4 focus:outline-none focus:border-[#FF5733] transition-colors w-full font-mono placeholder:text-[#EBE9E4]/30"
        />
        <button
          type="submit"
          class="font-mono text-sm uppercase tracking-widest text-[#FF5733] px-8 py-4 border border-transparent hover:border-[#FF5733] transition-colors shrink-0"
        >
          [ INITIATE_PROTOCOL ]
        </button>
      </form>
    </div>

    <!-- Bottom Row: Legal & Links -->
    <div class="flex flex-col lg:flex-row justify-between items-center mt-32 pt-8 border-t border-white/10 gap-6 font-mono text-[10px] md:text-xs uppercase tracking-widest text-[#EBE9E4]/50">
      <!-- Left: Copyright -->
      <span>&copy; {new Date().getFullYear()} RE/HUMAN. ALL RIGHTS RESERVED.</span>

      <!-- Right: Site Index -->
      <div class="flex gap-4 md:gap-6">
        <a href="#" class="hover:text-[#FF5733] transition-colors">//ARTICLES</a>
        <a href="#" class="hover:text-[#FF5733] transition-colors">//FAQ</a>
        <a href="#" class="hover:text-[#FF5733] transition-colors">//ABOUT_US</a>
        <a href="#" class="hover:text-[#FF5733] transition-colors">//CONTACT</a>
      </div>
    </div>
  </div>
</footer>

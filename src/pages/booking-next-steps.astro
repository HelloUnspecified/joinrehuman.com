---
import SqueezeLayout from "../layouts/SqueezeLayout.astro";
import SectionLabel from "../elements/SectionLabel.astro";
---

<SqueezeLayout
  title="You're In — Next Steps"
  description="Your architecture session is booked. Here's how to prepare so we can make the most of our time together."
  noindex
>
  <!-- Minimal Header -->
  <nav
    id="book-navbar"
    class="fixed top-0 left-0 right-0 z-[100] transition-all duration-300"
  >
    <div
      class="mx-auto flex max-w-[1400px] items-center justify-between px-6 py-5 md:px-10"
    >
      <a
        href="/"
        class="font-heading text-2xl font-black uppercase italic tracking-tight text-rh-chalk"
      >
        re/<span class="text-rh-ember">Human</span>
      </a>
      <SectionLabel
        text="SYS.CONFIRMED // SESSION_LOCKED"
        dot
        class="!text-rh-chalk/50"
      />
    </div>
  </nav>

  <script>
    const navbar = document.getElementById("book-navbar");
    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        navbar?.classList.add("backdrop-blur-xl", "bg-rh-ink/80");
      } else {
        navbar?.classList.remove("backdrop-blur-xl", "bg-rh-ink/80");
      }
    });
  </script>

  <!-- Confirmation Hero -->
  <section
    class="min-h-[60vh] flex flex-col items-center justify-center text-center px-6 pt-24 pb-16"
  >
    <SectionLabel
      text="> SYS.CONFIRM // SESSION_BOOKED"
      class="!text-rh-chalk/50"
    />

    <h1
      class="font-heading text-5xl md:text-7xl lg:text-8xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-chalk mt-8"
    >
      YOU'RE <span class="text-rh-ember">IN.</span>
    </h1>

    <p
      class="text-lg md:text-xl text-rh-chalk/70 leading-relaxed max-w-2xl mt-8"
    >
      Your architecture session is locked. Complete the steps below so we can
      hit the ground running.
    </p>

    <div class="mt-12 animate-bounce">
      <span class="font-mono text-xs uppercase tracking-widest text-rh-ember">
        [ SCROLL TO PREPARE ]
      </span>
    </div>
  </section>

  <!-- Next Steps Section -->
  <section class="py-32 px-6 md:px-10">
    <div class="mx-auto max-w-[900px]">
      <SectionLabel
        text="> SYS.PREP // MISSION_BRIEF"
        class="!text-rh-chalk/50 mb-12"
      />

      <h2
        class="font-heading text-4xl md:text-5xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-chalk mb-12"
      >
        Prepare for<br />Your Session.
      </h2>

      <div class="space-y-8">
        <!-- Step 1 -->
        <div
          class="flex gap-6 p-6 rounded-xl border border-rh-chalk/10 bg-rh-warm-dark"
        >
          <div
            class="flex-shrink-0 w-12 h-12 rounded-full bg-rh-ember flex items-center justify-center font-heading font-black text-lg text-white"
          >
            1
          </div>
          <div>
            <h3
              class="font-heading text-xl font-bold text-rh-chalk mb-2 uppercase"
            >
              Fill Out the Intake Form Below
            </h3>
            <p class="text-rh-chalk/70 leading-relaxed">
              This helps us understand your current ecosystem, goals, and
              challenges before we meet. The more context you share, the more
              value we can deliver in our session.
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div
          class="flex gap-6 p-6 rounded-xl border border-rh-chalk/10 bg-rh-warm-dark"
        >
          <div
            class="flex-shrink-0 w-12 h-12 rounded-full bg-rh-ember flex items-center justify-center font-heading font-black text-lg text-white"
          >
            2
          </div>
          <div>
            <h3
              class="font-heading text-xl font-bold text-rh-chalk mb-2 uppercase"
            >
              Check Your Email
            </h3>
            <p class="text-rh-chalk/70 leading-relaxed">
              You'll receive a calendar invite with the meeting link and session
              details. Add it to your calendar so nothing slips through the
              cracks.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div
          class="flex gap-6 p-6 rounded-xl border border-rh-chalk/10 bg-rh-warm-dark"
        >
          <div
            class="flex-shrink-0 w-12 h-12 rounded-full bg-rh-ember flex items-center justify-center font-heading font-black text-lg text-white"
          >
            3
          </div>
          <div>
            <h3
              class="font-heading text-xl font-bold text-rh-chalk mb-2 uppercase"
            >
              Think About Your Community Vision
            </h3>
            <p class="text-rh-chalk/70 leading-relaxed">
              Where are you today? Where do you want to be in 6 months? What's
              the biggest bottleneck? Come ready to think big — we'll handle the
              architecture.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Section -->
  <section class="py-32 px-6 md:px-10">
    <div class="mx-auto max-w-[900px]">
      <SectionLabel
        text="> SYS.STREAM // PREP_VIDEO"
        class="!text-rh-chalk/50 mb-8"
      />

      <h2
        class="font-heading text-3xl md:text-4xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-chalk mb-8"
      >
        Watch Before<br />Your Session.
      </h2>

      <!-- Video Container -->
      <div
        class="relative w-full aspect-video bg-rh-warm-dark rounded-2xl border border-rh-chalk/10 overflow-hidden"
      >
        <!-- Terminal Overlay Top Bar -->
        <div
          class="absolute top-0 left-0 right-0 z-10 flex items-center justify-between px-6 py-4 bg-gradient-to-b from-rh-ink/80 to-transparent"
        >
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-rh-ember/60"></span>
            <span class="w-3 h-3 rounded-full bg-rh-chalk/20"></span>
            <span class="w-3 h-3 rounded-full bg-rh-chalk/20"></span>
          </div>
          <span
            class="font-mono text-xs uppercase tracking-widest text-rh-chalk/30"
          >
            rh_session_prep.mp4
          </span>
        </div>

        <!-- Video Placeholder — replace with actual embed -->
        <div
          class="absolute inset-0 flex flex-col items-center justify-center"
        >
          <div
            class="w-20 h-20 rounded-full border-2 border-rh-ember flex items-center justify-center mb-6 hover:bg-rh-ember/10 transition-colors cursor-pointer"
          >
            <svg
              class="w-8 h-8 text-rh-ember ml-1"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M8 5v14l11-7z"></path>
            </svg>
          </div>
          <span
            class="font-mono text-xs uppercase tracking-widest text-rh-chalk/50"
          >
            [ CLICK TO PLAY ]
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Fillout Form Section -->
  <section class="py-32 px-6 md:px-10" id="intake">
    <div class="mx-auto max-w-[900px]">
      <SectionLabel
        text="> SYS.INPUT // INTAKE_FORM"
        class="!text-rh-chalk/50 mb-8"
      />

      <h2
        class="font-heading text-3xl md:text-4xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-chalk mb-4"
      >
        Tell Us About<br />Your Ecosystem.
      </h2>

      <p class="text-lg text-rh-chalk/70 leading-relaxed mb-12">
        Complete this quick intake so we come prepared with insights specific to
        your community.
      </p>

      <!-- Fillout Form Embed -->
      <div
        class="rounded-2xl border border-rh-chalk/10 overflow-hidden"
      >
        <!-- TODO: Replace YOUR_FORM_ID with actual Fillout form ID -->
        <script src="https://server.fillout.com/embed/v1/"></script>
        <div
          data-fillout-id="gctYQFDV2mus"
          data-fillout-embed-type="standard"
          data-fillout-inherit-parameters
          data-fillout-dynamic-resize
          style="width:100%;height:600px;"
        >
        </div>
      </div>
    </div>
  </section>

  <!-- Micro Footer -->
  <footer class="py-12 px-6 border-t border-rh-chalk/10">
    <div
      class="mx-auto max-w-[1400px] flex flex-col md:flex-row justify-between items-center gap-6"
    >
      <span
        class="font-mono text-xs uppercase tracking-widest text-rh-chalk/50"
      >
        &copy; 2026 RE/HUMAN. ALL RIGHTS RESERVED.
      </span>
      <div
        class="font-mono text-xs uppercase tracking-widest text-rh-chalk/50 flex items-center"
      >
        <span
          class="inline-block w-2 h-2 rounded-full bg-rh-ember animate-pulse mr-2"
        ></span>
        <span class="text-rh-ember">HUMAN PROTOCOL // ACTIVE</span>
      </div>
    </div>
  </footer>
</SqueezeLayout>

---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Deployments">
  <main class="main-wrapper relative overflow-hidden">
    <div class="max-w-4xl mx-auto pt-32 pb-24 px-6">

      <!-- Terminal Header -->
      <div class="font-mono text-sm uppercase tracking-widest text-[#121212]/50 dark:text-[#EBE9E4]/50 mb-8 flex items-center">
        <span class="w-2 h-2 rounded-full bg-[#FF5733] mr-3 animate-pulse"></span>
        > SYS.ARCHIVE // DEPLOYMENT_HISTORY
      </div>

      <!-- Title -->
      <h1 class="text-5xl font-black uppercase tracking-tighter text-[#121212] dark:text-[#EBE9E4] mb-12">
        DECLASSIFIED DOSSIERS.
      </h1>

      <!-- The File List -->
      <div class="border-t border-black/10 dark:border-white/10">

        <!-- File Row 001 -->
        <a href="/deployments/project-alpha" class="group block border-b border-black/10 dark:border-white/10 py-6 hover:bg-black/5 dark:hover:bg-white/5 transition-colors px-4">
          <div class="flex items-center justify-between gap-4">
            <div class="flex-1 min-w-0">
              <span class="font-mono text-xs text-[#121212]/50 dark:text-[#EBE9E4]/50 tracking-widest uppercase block mb-1">
                > FILE_001 // CREATOR_MIGRATION [ STATUS: RESOLVED ]
              </span>
              <span class="font-mono text-sm text-[#121212]/30 dark:text-[#EBE9E4]/30 tracking-widest uppercase">
                + $50k MRR // 85% RETENTION
              </span>
            </div>
            <span class="font-mono text-xs text-[#FF5733]/40 group-hover:text-[#FF5733] tracking-widest uppercase transition-colors whitespace-nowrap">
              [ OPEN_RECORD ]
            </span>
          </div>
        </a>

        <!-- File Row 002 -->
        <a href="/deployments/project-bravo" class="group block border-b border-black/10 dark:border-white/10 py-6 hover:bg-black/5 dark:hover:bg-white/5 transition-colors px-4">
          <div class="flex items-center justify-between gap-4">
            <div class="flex-1 min-w-0">
              <span class="font-mono text-xs text-[#121212]/50 dark:text-[#EBE9E4]/50 tracking-widest uppercase block mb-1">
                > FILE_002 // COMMUNITY_OVERHAUL [ STATUS: RESOLVED ]
              </span>
              <span class="font-mono text-sm text-[#121212]/30 dark:text-[#EBE9E4]/30 tracking-widest uppercase">
                + $35k MRR // 92% RETENTION
              </span>
            </div>
            <span class="font-mono text-xs text-[#FF5733]/40 group-hover:text-[#FF5733] tracking-widest uppercase transition-colors whitespace-nowrap">
              [ OPEN_RECORD ]
            </span>
          </div>
        </a>

        <!-- File Row 003 -->
        <a href="/deployments/project-charlie" class="group block border-b border-black/10 dark:border-white/10 py-6 hover:bg-black/5 dark:hover:bg-white/5 transition-colors px-4">
          <div class="flex items-center justify-between gap-4">
            <div class="flex-1 min-w-0">
              <span class="font-mono text-xs text-[#121212]/50 dark:text-[#EBE9E4]/50 tracking-widest uppercase block mb-1">
                > FILE_003 // REVENUE_RECAPTURE [ STATUS: RESOLVED ]
              </span>
              <span class="font-mono text-sm text-[#121212]/30 dark:text-[#EBE9E4]/30 tracking-widest uppercase">
                + $72k MRR // 78% RETENTION
              </span>
            </div>
            <span class="font-mono text-xs text-[#FF5733]/40 group-hover:text-[#FF5733] tracking-widest uppercase transition-colors whitespace-nowrap">
              [ OPEN_RECORD ]
            </span>
          </div>
        </a>

      </div>

      <!-- The Trap Door (Final CTA) -->
      <div class="mt-24 pt-16 border-t border-black/10 dark:border-white/10 flex flex-col items-center text-center">
        <span class="font-mono text-xs text-[#121212]/50 dark:text-[#EBE9E4]/50 uppercase tracking-widest mb-6">> END_OF_FILES // READY_TO_DEPLOY?</span>
        <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tighter text-[#121212] dark:text-[#EBE9E4] mb-10">
          YOUR METRICS <span class="text-[#FF5733]">ARE NEXT.</span>
        </h2>
        <a href="/apply" class="bg-[#121212] dark:bg-[#EBE9E4] text-[#EBE9E4] dark:text-[#121212] hover:bg-[#FF5733] dark:hover:bg-[#FF5733] hover:text-white transition-colors duration-300 font-black uppercase text-lg md:text-xl px-12 py-6 rounded-xl tracking-tight shadow-xl flex items-center gap-3">
          <span class="w-3 h-3 rounded-full bg-[#FF5733] animate-pulse"></span>
          > APPLY_FOR_BUILD
        </a>
      </div>

    </div>
  </main>
</Layout>

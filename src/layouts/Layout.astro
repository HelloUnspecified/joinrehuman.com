---
import "../css/tailwind.css";
import PostHog from "../components/functional/posthog.astro";
import Navbar from "../components/rehuman/Navbar.astro";
import Footer from "../components/rehuman/Footer.astro";

interface Props {
  title?: string;
}

const { title = "re/Human" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>re/Human | {title}</title>
    <meta
      name="description"
      content="In the age of AI, your only unfair advantage is your people. re/Human builds systems that scale authentic connection."
    />
    <link rel="icon" href="/favicon.webp" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,100..900;1,100..900&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- FOUC Prevention: Apply theme before paint -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("rh-theme");
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>

    <PostHog />
  </head>
  <body
    class="bg-warm-light text-text-light dark:bg-warm-dark dark:text-text-dark font-body antialiased transition-colors duration-300"
  >
    <!-- Noise Overlay -->
    <svg class="pointer-events-none fixed inset-0 z-[9999] h-full w-full opacity-[0.03]" aria-hidden="true">
      <filter id="noiseFilter">
        <feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="4" stitchTiles="stitch" />
      </filter>
      <rect width="100%" height="100%" filter="url(#noiseFilter)" />
    </svg>

    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

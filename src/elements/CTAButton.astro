---
interface Props {
  href: string;
  variant?: "solid" | "contrast";
  class?: string;
}

const { href, variant = "solid", class: className = "" } = Astro.props;

const variantClasses: Record<string, string> = {
  solid:
    "inline-block bg-rh-ember text-rh-warm-light font-black text-2xl uppercase tracking-widest rounded-full hover:scale-105 transition-transform duration-300 shadow-2xl shadow-rh-ember/20 px-12 py-6",
  contrast:
    "bg-rh-ink dark:bg-rh-chalk text-rh-chalk dark:text-rh-ink hover:bg-rh-ember dark:hover:bg-rh-ember hover:text-white transition-colors duration-300 font-black uppercase text-lg md:text-xl px-12 py-6 rounded-xl tracking-tight shadow-xl flex items-center gap-3",
};
---

<a href={href} class:list={[variantClasses[variant], className]}>
  <slot />
</a>
